    <!-- First-run onboarding / tutorial (Step 6.9.16) -->
    <string name="onboarding_skip">Skip</string>
    <string name="onboarding_next">Next</string>
    <string name="onboarding_done">Get started</string>
    <string name="onboarding_objective_title">Welcome to Snake</string>
    <string name="onboarding_objective_body">Guide the snake to the glowing food and eat it to grow longer. It moves on its own and never stops, so keep it clear of the outer walls, the obstacles and its own tail - a single hit ends the run. Eat without hesitating to build a combo multiplier and climb the high-score tables.</string>
    <string name="onboarding_controls_title">Steer the snake</string>
    <string name="onboarding_controls_body">You only ever change direction - the snake keeps moving forward by itself. Choose the control style that suits you in Settings; here is how each one works.</string>
    <string name="onboarding_controls_swipe">Swipe</string>
    <string name="onboarding_controls_swipe_desc">Flick anywhere on the board toward the way you want to go.</string>
    <string name="onboarding_controls_tap">Tap to turn</string>
    <string name="onboarding_controls_tap_desc">Two buttons steer left or right, relative to your heading.</string>
    <string name="onboarding_controls_dpad">D-pad</string>
    <string name="onboarding_controls_dpad_desc">A classic on-screen four-way pad for absolute directions.</string>
    <string name="onboarding_food_title">Eat to grow</string>
    <string name="onboarding_food_body">Food appears one piece at a time. Most of it feeds the snake, but read the colour - some pieces are working against you. Ignore a piece too long and it vanishes, so be decisive.</string>
    <string name="onboarding_food_grow">Grow</string>
    <string name="onboarding_food_grow_desc">Green pieces add length and score. The larger the piece, the bigger the reward.</string>
    <string name="onboarding_food_shrink">Shrink</string>
    <string name="onboarding_food_shrink_desc">Warm pieces trim your tail - handy when you are boxed in, but they cost points.</string>
    <string name="onboarding_food_mystery">Mystery</string>
    <string name="onboarding_food_mystery_desc">A \"?\" hides a random grow or shrink. Eat it to find out which.</string>
    <string name="onboarding_specials_title">Power-ups &amp; hazards</string>
    <string name="onboarding_specials_body">Deeper into a run, rare special blocks appear. Power-ups help you; hazards are ringed in red and make life harder. Prefer a gentler game? Turn hazards off any time in Settings.</string>
    <string name="onboarding_powerups">Power-ups</string>
    <string name="onboarding_hazards">Hazards</string>
    <string name="onboarding_jackpot">Jackpot</string>
    <string name="onboarding_explosion">Explosion</string>
    <string name="onboarding_lightning_desc">Speeds the snake up for a short, frantic burst.</string>
    <string name="onboarding_star_desc">Invincible: pass straight through walls, obstacles and your own tail.</string>
    <string name="onboarding_freeze_desc">Slows time right down so you can pick a safe line.</string>
    <string name="onboarding_jackpot_desc">A large score bonus plus a few extra segments at once.</string>
    <string name="onboarding_quake_desc">Shakes the whole board, making it hard to read for a while.</string>
    <string name="onboarding_explosion_desc">Splits the snake in two; the severed tail stays lethal until it fades.</string>
    <string name="onboarding_snail_desc">Slows you to a crawl - manageable, but you lose your rhythm.</string>

