<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: the "Serpentine" - the Classic-skin snake as one
     smooth S-shaped tube (round-capped stroke with a lighter core sheen, like
     the in-game tube body), a bright lime head with an eye, and the gold food
     just ahead of it. A dark offset copy underneath acts as a soft drop shadow
     over the Meadow background. Scaled to 0.92 around the centre so nothing is
     cropped by round launcher masks. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.92"
        android:scaleY="0.92">

        <!-- Drop shadow: the whole snake + food, offset down -->
        <group android:translateY="2.4">
            <path
                android:pathData="M36,78 C58,78 72,70 72,58 C72,46 36,50 36,38 C36,30 43,26 52,26"
                android:strokeColor="#47000000"
                android:strokeWidth="13"
                android:strokeLineCap="round" />
            <path
                android:fillColor="#47000000"
                android:pathData="M45.4,26 a9.6,9.6 0 1,0 19.2,0 a9.6,9.6 0 1,0 -19.2,0 Z" />
            <path
                android:fillColor="#47000000"
                android:pathData="M66,35 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z" />
        </group>

        <!-- Body: a continuous S-shaped tube with a lighter core sheen -->
        <path
            android:pathData="M36,78 C58,78 72,70 72,58 C72,46 36,50 36,38 C36,30 43,26 52,26"
            android:strokeColor="#3FA34D"
            android:strokeWidth="13"
            android:strokeLineCap="round" />
        <path
            android:pathData="M36,78 C58,78 72,70 72,58 C72,46 36,50 36,38 C36,30 43,26 52,26"
            android:strokeColor="#5FBE6C"
            android:strokeWidth="4.6"
            android:strokeAlpha="0.45"
            android:strokeLineCap="round" />

        <!-- Head + glossy highlight -->
        <path
            android:fillColor="#7CFC00"
            android:pathData="M45.4,26 a9.6,9.6 0 1,0 19.2,0 a9.6,9.6 0 1,0 -19.2,0 Z" />
        <path
            android:fillColor="#CDFF85"
            android:fillAlpha="0.9"
            android:pathData="M48.9,22.8 a2.6,2.6 0 1,0 5.2,0 a2.6,2.6 0 1,0 -5.2,0 Z" />
        <!-- Eye + catchlight -->
        <path
            android:fillColor="#0E1F14"
            android:pathData="M56.1,23.6 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M58.7,22.6 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0 Z" />

        <!-- Food + highlight -->
        <path
            android:fillColor="#FFC107"
            android:pathData="M66,35 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z" />
        <path
            android:fillColor="#FFE082"
            android:pathData="M67.6,33.2 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0 Z" />
    </group>
</vector>
