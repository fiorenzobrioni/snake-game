<?xml version="1.0" encoding="utf-8"?>
<!-- Themed-icon (Android 13+) monochrome layer: a flat single-colour silhouette
     of the Serpentine foreground - the S-shaped tube, the head and the food.
     The launcher tints this with the user's theme, so the fill colour itself is
     irrelevant - only the shapes matter. Same geometry and transform as
     ic_launcher_foreground.xml. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.9"
        android:scaleY="0.9"
        android:translateY="1.4">

        <!-- Body: the S-shaped tube -->
        <path
            android:pathData="M36,75.1 C58,75.1 72,68.1 72,57.5 C72,47 36,50.5 36,39.9 C36,32.9 43,29.4 52,29.4"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="13"
            android:strokeLineCap="round" />

        <!-- Head -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M45.4,29.4 a9.6,9.6 0 1,0 19.2,0 a9.6,9.6 0 1,0 -19.2,0 Z" />

        <!-- Food -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M66,37.3 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z" />
    </group>
</vector>
