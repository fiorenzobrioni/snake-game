<?xml version="1.0" encoding="utf-8"?>
<!-- Themed-icon (Android 13+) monochrome layer: a flat single-colour silhouette
     of the Serpentine foreground - the S-shaped tube, the head and the food.
     The launcher tints this with the user's theme, so the fill colour itself is
     irrelevant - only the shapes matter. Scaled to 0.92 around the centre,
     mirroring ic_launcher_foreground.xml. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.92"
        android:scaleY="0.92">

        <!-- Body: the S-shaped tube -->
        <path
            android:pathData="M36,78 C58,78 72,70 72,58 C72,46 36,50 36,38 C36,30 43,26 52,26"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="13"
            android:strokeLineCap="round" />

        <!-- Head -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M45.4,26 a9.6,9.6 0 1,0 19.2,0 a9.6,9.6 0 1,0 -19.2,0 Z" />

        <!-- Food -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M66,35 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z" />
    </group>
</vector>
